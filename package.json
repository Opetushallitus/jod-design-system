{
  "name": "@jod/design-system",
  "version": "0.0.0",
  "private": true,
  "license": "EUPL-1.2",
  "files": [
    "dist",
    "lib"
  ],
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.js"
    },
    "./icons": {
      "import": "./lib/icons/index.js",
      "require": "./lib/icons/index.js"
    },
    "./dist/main.css": "./dist/main.css",
    "./lib/theme.css": "./lib/theme.css"
  },
  "scripts": {
    "dev": "vite build -w",
    "build": "tsc && vite build",
    "lint": "oxlint",
    "format": "oxfmt",
    "test:unit": "vitest --run",
    "test:unit-update-snapshot": "vitest --run -u",
    "test:watch": "vitest --watch",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@ark-ui/react": "5.36.2",
    "@floating-ui/react": "0.27.16",
    "@headlessui/react": "2.2.9",
    "cva": "1.0.0-beta.4",
    "focus-trap-react": "12.0.0",
    "motion": "12.35.0",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "5.0.2",
    "@lavamoat/preinstall-always-fail": "3.0.0",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-links": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/node": "24.1.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-storybook": "10.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "storybook": "10.4.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.10.0",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^24.0.0",
    "npm": ">=11.10.0"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "vite>esbuild#0.27.1": false
    }
  }
}
